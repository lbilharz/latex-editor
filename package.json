{
  "name": "@lbilharz/accessible-math-editor",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Accessible LaTeX formula editor for visually impaired students",
  "main": "dist/accessible-math-editor.umd.js",
  "module": "dist/accessible-math-editor.es.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/accessible-math-editor.es.js",
      "require": "./dist/accessible-math-editor.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "BUILD_DEMO=true vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "python3 -m http.server 8090"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lbilharz/latex-editor.git"
  },
  "license": "MIT",
  "homepage": "https://latex-mathml-editor.vercel.app",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1"
  }
}
